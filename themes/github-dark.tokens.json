{
  "$description": "GitHub Dark — adapted from the GitHub editor theme by Pyae Sone Aung.",
  "color": {
    "$type": "color",
    "background": {
      "$value": { "colorSpace": "srgb", "components": [0.051, 0.067, 0.09], "hex": "#0D1117" },
      "$description": "Primary application background"
    },
    "surface": {
      "$value": { "colorSpace": "srgb", "components": [0.004, 0.016, 0.035], "hex": "#010409" },
      "$description": "Elevated surface background (panels, cards, table cells)"
    },
    "border": {
      "$value": { "colorSpace": "srgb", "components": [0.239, 0.267, 0.302], "hex": "#3D444D" },
      "$description": "Default border and separator color"
    },
    "text": {
      "primary": {
        "$value": { "colorSpace": "srgb", "components": [0.941, 0.965, 0.988], "hex": "#F0F6FC" },
        "$description": "Primary text color for content and headings"
      },
      "secondary": {
        "$value": { "colorSpace": "srgb", "components": [0.569, 0.596, 0.631], "hex": "#9198A1" },
        "$description": "Secondary text for labels, captions, and muted content"
      },
      "tertiary": {
        "$value": { "colorSpace": "srgb", "components": [0.396, 0.424, 0.463], "hex": "#656C76" },
        "$description": "Tertiary text for placeholders and disabled content"
      }
    },
    "accent": {
      "default": {
        "$value": { "colorSpace": "srgb", "components": [0.022, 0.463, 1], "hex": "#0576FF" },
        "$description": "Primary accent color for interactive elements and focus indicators"
      },
      "hover": {
        "$value": { "colorSpace": "srgb", "components": [0.267, 0.576, 0.961], "hex": "#4493F8" },
        "$description": "Accent color on hover state"
      },
      "on-accent": {
        "$value": { "colorSpace": "srgb", "components": [1, 1, 1], "hex": "#FFFFFF" },
        "$description": "Text color used on accent-colored backgrounds"
      },
      "subtle": {
        "$value": { "colorSpace": "srgb", "components": [0.022, 0.463, 1], "alpha": 0.1, "hex": "#0576FF" },
        "$description": "Subtle accent tint for selected items and active states"
      }
    },
    "state": {
      "edited": {
        "$value": { "colorSpace": "srgb", "components": [0.733, 0.502, 0.035], "alpha": 0.15, "hex": "#BB8009" },
        "$description": "Background tint indicating an edited/modified cell"
      },
      "hover-row": {
        "$value": { "colorSpace": "srgb", "components": [0.082, 0.106, 0.137], "hex": "#151B23" },
        "$description": "Background highlight for hovered table rows"
      },
      "danger": {
        "$value": { "colorSpace": "srgb", "components": [0.973, 0.318, 0.286], "hex": "#F85149" },
        "$description": "Destructive action color for errors, deletions, and warnings"
      },
      "selection": {
        "$value": { "colorSpace": "srgb", "components": [0.022, 0.463, 1], "alpha": 0.4, "hex": "#0576FF" },
        "$description": "Background color for selected cells and text selection"
      }
    },
    "chrome": {
      "status-bar": {
        "$value": { "colorSpace": "srgb", "components": [0.004, 0.016, 0.035], "hex": "#010409" },
        "$description": "Status bar background color"
      },
      "gutter": {
        "$value": { "colorSpace": "srgb", "components": [0.051, 0.067, 0.09], "hex": "#0D1117" },
        "$description": "Row number gutter background"
      },
      "line-number": {
        "$value": { "colorSpace": "srgb", "components": [0.569, 0.596, 0.631], "hex": "#9198A1" },
        "$description": "Row number text color"
      }
    }
  },
  "$extensions": {
    "dev.colomin": {
      "appearance": "dark"
    }
  }
}
