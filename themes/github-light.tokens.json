{
  "$description": "GitHub Light — adapted from the GitHub editor theme by Pyae Sone Aung.",
  "color": {
    "$type": "color",
    "background": {
      "$value": { "colorSpace": "srgb", "components": [1, 1, 1], "hex": "#FFFFFF" },
      "$description": "Primary application background"
    },
    "surface": {
      "$value": { "colorSpace": "srgb", "components": [0.965, 0.973, 0.98], "hex": "#F6F8FA" },
      "$description": "Elevated surface background (panels, cards, table cells)"
    },
    "border": {
      "$value": { "colorSpace": "srgb", "components": [0.82, 0.851, 0.878], "hex": "#D1D9E0" },
      "$description": "Default border and separator color"
    },
    "text": {
      "primary": {
        "$value": { "colorSpace": "srgb", "components": [0.122, 0.137, 0.157], "hex": "#1F2328" },
        "$description": "Primary text color for content and headings"
      },
      "secondary": {
        "$value": { "colorSpace": "srgb", "components": [0.349, 0.388, 0.431], "hex": "#59636E" },
        "$description": "Secondary text for labels, captions, and muted content"
      },
      "tertiary": {
        "$value": { "colorSpace": "srgb", "components": [0.506, 0.545, 0.596], "hex": "#818B98" },
        "$description": "Tertiary text for placeholders and disabled content"
      }
    },
    "accent": {
      "default": {
        "$value": { "colorSpace": "srgb", "components": [0, 0.431, 0.859], "hex": "#006EDB" },
        "$description": "Primary accent color for interactive elements and focus indicators"
      },
      "hover": {
        "$value": { "colorSpace": "srgb", "components": [0.035, 0.412, 0.855], "hex": "#0969DA" },
        "$description": "Accent color on hover state"
      },
      "on-accent": {
        "$value": { "colorSpace": "srgb", "components": [1, 1, 1], "hex": "#FFFFFF" },
        "$description": "Text color used on accent-colored backgrounds"
      },
      "subtle": {
        "$value": { "colorSpace": "srgb", "components": [0, 0.431, 0.859], "alpha": 0.1, "hex": "#006EDB" },
        "$description": "Subtle accent tint for selected items and active states"
      }
    },
    "state": {
      "edited": {
        "$value": { "colorSpace": "srgb", "components": [1, 0.973, 0.773], "hex": "#FFF8C5" },
        "$description": "Background tint indicating an edited/modified cell"
      },
      "hover-row": {
        "$value": { "colorSpace": "srgb", "components": [0.965, 0.973, 0.98], "hex": "#F6F8FA" },
        "$description": "Background highlight for hovered table rows"
      },
      "danger": {
        "$value": { "colorSpace": "srgb", "components": [0.82, 0.141, 0.184], "hex": "#D1242F" },
        "$description": "Destructive action color for errors, deletions, and warnings"
      },
      "selection": {
        "$value": { "colorSpace": "srgb", "components": [0, 0.431, 0.859], "alpha": 0.4, "hex": "#006EDB" },
        "$description": "Background color for selected cells and text selection"
      }
    },
    "chrome": {
      "status-bar": {
        "$value": { "colorSpace": "srgb", "components": [0.965, 0.973, 0.98], "hex": "#F6F8FA" },
        "$description": "Status bar background color"
      },
      "gutter": {
        "$value": { "colorSpace": "srgb", "components": [1, 1, 1], "hex": "#FFFFFF" },
        "$description": "Row number gutter background"
      },
      "line-number": {
        "$value": { "colorSpace": "srgb", "components": [0.349, 0.388, 0.431], "hex": "#59636E" },
        "$description": "Row number text color"
      }
    }
  },
  "$extensions": {
    "dev.colomin": {
      "appearance": "light"
    }
  }
}
